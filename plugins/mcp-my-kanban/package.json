{
  "name": "mcp-my-kanban",
  "version": "1.5.7",
  "description": "Kanban board MCP server for agent team coordination",
  "main": "dist/mcp-stdio.js",
  "bin": {
    "mcp-my-kanban": "dist/mcp-stdio.js"
  },
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/",
    "!dist/__tests__/",
    "skills/",
    ".claude-plugin/",
    "README.md",
    "README.ko.md"
  ],
  "scripts": {
    "dev": "tsx watch src/mcp-stdio.ts",
    "build": "tsc && copyfiles -u 1 \"src/web/public/**/*\" dist/",
    "prepublishOnly": "npm run build",
    "start": "node dist/mcp-stdio.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ARaTasia/mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "better-sqlite3": "^12.6.2",
    "express": "^4.19.2",
    "nanoid": "^5.0.7",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.12",
    "@vitest/coverage-v8": "^2.1.9",
    "copyfiles": "^2.4.1",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  }
}
