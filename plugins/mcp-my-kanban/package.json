{
  "name": "mcp-my-kanban",
  "version": "1.0.3",
  "description": "Kanban board MCP server for agent team coordination",
  "main": "dist/mcp-stdio.js",
  "bin": {
    "mcp-my-kanban": "./dist/mcp-stdio.js"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/mcp-stdio.ts",
    "build": "tsc",
